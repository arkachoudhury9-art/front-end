# Backend API base URL
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Use mock data instead of calling the live REST API
NEXT_PUBLIC_USE_MOCK_API=true

# Use mock WebSocket instead of connecting to ws://127.0.0.1:8000/ws/anomaly
NEXT_PUBLIC_USE_MOCK_WEBSOCKET=true

# Live WebSocket URL (used when NEXT_PUBLIC_USE_MOCK_WEBSOCKET=false)
NEXT_PUBLIC_ANOMALY_WS_URL=ws://127.0.0.1:8000/ws/anomaly

# Use mock reasoning WebSocket
NEXT_PUBLIC_USE_MOCK_REASONING_WEBSOCKET=true

# Live reasoning WebSocket URL
NEXT_PUBLIC_REASONING_WS_URL=ws://127.0.0.1:8000/reasoning/events
